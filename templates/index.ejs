<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Steam Web Booster v1.0</title>
    <style>
        body { background-color: #1a1d20; }
        .form-control, .form-select { 
            background-color: #2b2f32; 
            border-color: #495057; 
            color: white; 
        }
        .form-control:focus, .form-select:focus { 
            background-color: #2b2f32; 
            color: white; 
            border-color: #0d6efd; 
            box-shadow: none; 
        }
        .form-control::placeholder {
            color: #6c757d;
            opacity: 1;
        }
        .text-info-custom { color: #0dcaf0; font-weight: bold; }
        .card-custom {
            background-color: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .version-badge {
            font-size: 0.4em;
            vertical-align: middle;
            background-color: #198754;
            padding: 2px 6px;
            border-radius: 4px;
            letter-spacing: 1px;
        }
    </style>
</head>
<body class="text-white p-5">
    <div class="container mt-5" style="max-width: 450px;">
        <h2 class="text-center mb-4">
            Steam Booster <span class="version-badge">v1.1</span>
        </h2>

        <% if (session.running) { %>
            <div class="card bg-success p-4 text-center text-white border-0 shadow">
                <h4 class="mb-2">⚡ BOOSTING IN CORSO ⚡</h4>
                <hr class="opacity-25">
                <div class="mb-1">Account: <strong><%= session.username %></strong></div>
                <div>Gioco: <strong><%= session.game_name %></strong></div>
            </div>
            <form action="/stop" method="post" class="mt-3">
                <button class="btn btn-danger w-100 fw-bold shadow py-2">FERMA SESSIONE</button>
            </form>

        <% } else { %>
            <form action="/start" method="post" class="card card-custom p-4 shadow">
                <% if (session.error) { %>
                    <div class="alert alert-danger p-2 small text-center"><%= session.error %></div>
                <% } %>
                
                <div class="mb-3">
                    <label class="small text-secondary mb-1">Dati Account</label>
                    <input type="text" name="username" class="form-control mb-2" placeholder="Username" required>
                    <input type="password" name="password" class="form-control" placeholder="Password" required>
                </div>

                <div class="mb-3">
                    <label class="small text-info-custom mb-1">Steam Guard (Codice App)</label>
                    <input type="text" 
                        name="auth_code" 
                        class="form-control border-info text-center fw-bold text-uppercase" 
                        placeholder="ABC12" 
                        minlength="5" 
                        maxlength="5" 
                        pattern="[a-zA-Z0-9]{5}"
                        style="letter-spacing: 3px; font-size: 1.2rem;" 
                        required>
                </div>
                
                <div class="mb-4">
                    <label class="small text-secondary mb-1">Gioco da Boostare</label>
                    <select name="game_id" id="gameSelect" class="form-select mb-2" onchange="toggleCustomInput()" required>
                        <option value="252490">Rust</option>
                        <option value="730">Counter-Strike 2</option>
                        <option value="1808500">ARC Raiders</option>
                        <option value="218620">PAYDAY 2</option>
                        <option value="230410">Warframe</option>
                        <option value="221100">DayZ</option>
                        <option value="4000">Garry's Mod</option>
                        <option value="107410">Arma 3</option>
                        <option value="2799860">Inazuma Eleven: Victory Road</option>
                        <option value="custom">-- Altro (Inserisci ID manualmente) --</option>
                    </select>
                    
                    <input type="number" id="customInput" class="form-control border-warning" 
                           placeholder="Inserisci AppID (es. 440)" style="display: none;">
                </div>

                <button type="submit" id="submitBtn" class="btn btn-primary w-100 fw-bold py-3 shadow d-flex align-items-center justify-content-center">
                    <span id="btnText">ACCEDI E AVVIA BOOST</span>
                    <div id="btnSpinner" class="spinner-border spinner-border-sm ms-2" role="status" style="display: none;">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </button>

                <script>
                    const form = document.querySelector('form');
                    const btn = document.getElementById('submitBtn');
                    const btnText = document.getElementById('btnText');
                    const btnSpinner = document.getElementById('btnSpinner');

                    if (form && btn) {
                        form.onsubmit = function() {
                            btn.disabled = true;
                            btn.classList.replace('btn-primary', 'btn-secondary');
                            btnText.innerText = "CONTROLLO CREDENZIALI...";
                            btnSpinner.style.display = "inline-block";
                            return true; 
                        };
                    }
                </script>
            </form>
        <% } %>
    </div>

    <script>
        function toggleCustomInput() {
            var select = document.getElementById("gameSelect");
            var input = document.getElementById("customInput");
            if (select.value === "custom") {
                input.style.display = "block";
                input.required = true;
                input.name = "game_id"; 
                select.name = "old_game_id"; 
            } else {
                input.style.display = "none";
                input.required = false;
                input.name = "custom_game_id";
                select.name = "game_id"; 
            }
        }
    </script>
</body>
</html>